# Copy this file to .env and adjust if needed.
# All variables are prefixed with SPECTRA_ (see app/core/config.py).

SPECTRA_APP_NAME="Spectra API"
SPECTRA_ENVIRONMENT=development
SPECTRA_HOST=127.0.0.1
SPECTRA_PORT=8000

# Informational only in Phase 0 — no model runs yet.
SPECTRA_POWER_PROFILE=BALANCED
SPECTRA_MAX_VRAM_BUDGET_GB=4.5
SPECTRA_MAX_RAM_BUDGET_GB=10.0
